# Basirah Environment Configuration
# Copy this file to .env and update the values

# PostgreSQL Configuration
POSTGRES_DB=basirah
POSTGRES_USER=basirah
POSTGRES_PASSWORD=changeme_strong_password_here

# GPU Configuration (DGX device indices)
# Note: Single GPU setup - only vLLM uses GPU
VLLM_GPU=0

# Collection Name
COLLECTION_NAME=basirah_corpus

# Logging
LOG_LEVEL=info
